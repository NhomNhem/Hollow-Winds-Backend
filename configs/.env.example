# Server Configuration
PORT=8080
ENV=development

# Database (Supabase)
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT Secret (Change in production!)
JWT_SECRET=your-secret-key-here-change-in-production

# PlayFab
PLAYFAB_TITLE_ID=your-title-id
PLAYFAB_SECRET_KEY=your-secret-key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Redis (Upstash)
REDIS_URL=redis://default:password@host:port

# CORS
ALLOWED_ORIGINS=http://localhost:3000,https://yourgame.com

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=60s
